extends layout

mixin hostSampleChart(chart)
  .card
    .card-body
      h5.card-title= chart.title
      if chart.summaryItems && chart.summaryItems.length > 0
        each summaryItem, index in chart.summaryItems
          p.text-muted.small(class=index === chart.summaryItems.length - 1 ? 'mb-2' : 'mb-1')
            b #{summaryItem.label}:
            |  #{summaryItem.text}
      else if chart.summaryText
        p.text-muted.small.mb-2= chart.summaryText
      if !chart.hideLegend
        .mb-2
          each series in chart.series
            span.badge.badge-light.mr-2.mb-2
              span(style=`display:inline-block;width:0.75rem;height:0.75rem;border-radius:50%;background-color:${series.color};margin-right:0.4rem;vertical-align:middle;`)
              | #{series.label}
      svg(width=chart.width, height=chart.height, viewBox=`0 0 ${chart.width} ${chart.height}`, style='width:100%;height:auto;border:1px solid #ddd;border-radius:4px;')
        rect(x='0', y='0', width=chart.width, height=chart.height, fill='#ffffff')
        each tick in chart.ticks
          line(
            x1=chart.padding.left,
            y1=tick.y,
            x2=chart.width - chart.padding.right,
            y2=tick.y,
            stroke='#e9ecef',
            'stroke-width'='1'
          )
          text(
            x=chart.padding.left - 8,
            y=tick.y + 4,
            'text-anchor'='end',
            'font-size'='11',
            fill='#6c757d'
          )= tick.label
        line(
          x1=chart.padding.left,
          y1=chart.height - chart.padding.bottom,
          x2=chart.width - chart.padding.right,
          y2=chart.height - chart.padding.bottom,
          stroke='#adb5bd',
          'stroke-width'='1'
        )
        line(
          x1=chart.padding.left,
          y1=chart.padding.top,
          x2=chart.padding.left,
          y2=chart.height - chart.padding.bottom,
          stroke='#adb5bd',
          'stroke-width'='1'
        )
        each series in chart.series
          if series.polylinePoints
            polyline(
              points=series.polylinePoints,
              fill='none',
              stroke=series.color,
              'stroke-width'='3',
              'stroke-linejoin'='round',
              'stroke-linecap'='round'
            )
          if series.lastPoint
            circle(cx=series.lastPoint.x, cy=series.lastPoint.y, r='4', fill=series.color)
      .d-flex.justify-content-between.mt-2.text-muted.small
        span= chart.startLabel
        span= chart.endLabel

block content
  .row.mb-3
    .col-md-8
      h1 Host samples
      p.text-muted.mb-0 Review host monitor samples stored in the GCS Tool database. All timestamps are shown in JST.
    .col-md-4.text-md-right
      a.btn.btn-outline-secondary.mt-2.mt-md-0.mr-2(href='/lennart/host-trends') 30-day trends
      a.btn.btn-outline-secondary.mt-2.mt-md-0(href='/lennart') Back to Lennart tools

  if error
    .alert.alert-danger= error

  .row.mb-3
    .col-lg-4
      .card
        .card-body
          h5.card-title Filters
          form(method='get', action='/lennart/host-samples')
            .form-group
              label(for='hostname') Hostname
              select#hostname.form-control(name='hostname')
                option(value='') All hosts
                each host in hostnames
                  option(value=host, selected=host === hostname)= host
            .form-group
              label(for='limit') Rows
              input#limit.form-control(type='number', name='limit', min='1', max='200', value=limit)
            button.btn.btn-primary(type='submit') Apply
    .col-lg-8
      .card
        .card-body
          h5.card-title Overview
          if latestSample && overview
            p.mb-1
              b Latest sample:
              |  #{overview.latestTsShort} JST
            p.mb-1
              b Host:
              |  #{latestSample.hostname}
            p.mb-1
              b Window:
              |  #{overview.oldestTsShort} JST to #{overview.latestTsShort} JST (#{overview.windowDurationText})
            p.mb-1
              b Rows:
              |  #{overview.displayedRows} shown of #{overview.matchingRows} matching rows
            p.mb-1
              b Memory:
              |  #{latestSample.memUsedMb} / #{latestSample.memTotalMb} MB used, #{latestSample.memAvailableMb} MB available
            p.mb-1
              b Current load:
              |  #{latestSample.load}
            p.text-muted.small.mb-3 Summary stats below are based on the displayed rows.
            table.table.table-sm.table-bordered.mb-0
              thead.thead-light
                tr
                  th Metric
                  th Latest
                  th Average
                  th Max
              tbody
                each metric in overview.metrics
                  tr
                    td= metric.label
                    td= metric.latest
                    td= metric.average
                    td= metric.max
          else
            p.mb-0 No samples found for the selected filter.

  if charts.length > 0
    .row.mb-3
      each chart in charts
        .col-xl-6
          +hostSampleChart(chart)

  if pm2MemoryCharts.length > 0
    .row.mb-2
      .col
        h4 PM2 process memory
        p.text-muted.mb-0 Aggregated by PM2 process name across the displayed rows. A steady upward trend without settling back down can indicate a memory leak.
    .row.mb-3
      each chart in pm2MemoryCharts
        .col-xl-6
          +hostSampleChart(chart)

  if samples.length > 0
    .row
      .col
        table.table.table-sm.table-striped.table-bordered
          thead.thead-dark
            tr
              th Timestamp (JST)
              th Hostname
              th Memory
              th Swap
              th Load
              th Root
              th Processes
          tbody
            each sample in samples
              tr
                td= sample.tsShort
                td= sample.hostname
                td #{sample.memUsedMb} / #{sample.memTotalMb} MB
                td #{sample.swapUsedMb} / #{sample.swapTotalMb} MB
                td= sample.load
                td #{sample.rootUsedPct}%
                td
                  div Node: #{sample.processCount}
                  div PM2: #{sample.pm2ProcessCount}
              tr
                td(colspan='7')
                  details
                    summary Process details
                    .row.mt-3
                      .col-lg-6
                        h6 Node processes
                        pre(style='max-height:20rem;overflow:auto;')= sample.nodeProcessesText
                      .col-lg-6
                        h6 PM2 processes
                        pre(style='max-height:20rem;overflow:auto;')= sample.pm2ProcessesText
  else if !error
    .alert.alert-secondary No host samples are stored yet.
