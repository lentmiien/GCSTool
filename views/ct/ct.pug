extends ../layout

mixin openCaseTable(caseRows, showStaff)
  .table-responsive
    table.table.table-striped.table-hover.mb-0
      thead
        tr
          th Order number
          if showStaff
            th Staff in charge
          th Customer ID
          th Current complaint
          th Complaint date
          th Last updated
      tbody
        each caseEntry in caseRows
          tr(class=caseEntry.needs_review ? 'ct-needs-review-row' : '')
            td
              a(href=`/ct/case/${encodeURIComponent(caseEntry.order_number)}`)= caseEntry.order_number
            if showStaff
              td= caseEntry.staff_in_charge || 'Unassigned'
            td= caseEntry.customer_id || '—'
            td= caseEntry.effective_complaint || '—'
            td= caseEntry.complaint_date || '—'
            td
              span= caseEntry.updated_at_display || '—'
              if caseEntry.needs_review
                span.badge.badge-warning.ml-2(title='Last updated more than seven days ago') Need review

block content
  .d-flex.flex-column.flex-lg-row.justify-content-between.align-items-lg-center.mb-4
    .mb-3.mb-lg-0
      h1.mb-1 Cases
      p.text-muted.mb-0 Open an order number to continue or create a new case.
    .btn-group
      a.btn.btn-outline-secondary(href='/ct/analytics') Analytics
      if role === 'admin'
        a.btn.btn-outline-secondary(href='/ct/admin') Admin

  if message
    .alert.alert-info= message

  if complaintTypes.length === 0
    .alert.alert-warning
      | No complaint types are configured yet.
      if role === 'admin'
        |  Add them on the admin page before assigning complaints.

  .card.mb-4
    .card-body
      h2.h4.mb-3 Open Case
      form(method='post', action='/ct/open')
        .form-row.align-items-end
          .form-group.col-md-8.mb-2.mb-md-0
            label(for='order_number') Order number
            input#order_number.form-control(type='text', name='order_number', placeholder='Enter order number', required=true, autofocus=true)
          .form-group.col-md-4.mb-0
            button.btn.btn-primary.btn-block(type='submit') Open case

  .card.mb-4(class=recentItemSummary.rows.length > 0 ? 'border-warning' : '')
    .card-header.d-flex.flex-column.flex-md-row.justify-content-between.align-items-md-center
      div
        h2.h4.mb-1 Recent repeated item issues
        p.text-muted.mb-0
          | Real item codes in at least three separate cases dated #{recentItemSummary.periodStart}–#{recentItemSummary.periodEnd}, with the latest complaint on or after #{recentItemSummary.latestComplaintStartDate}.
      span.badge.mt-2.mt-md-0(
        class=recentItemSummary.rows.length > 0 ? 'badge-warning' : 'badge-secondary'
      )= `${recentItemSummary.rows.length} item${recentItemSummary.rows.length === 1 ? '' : 's'}`
    if recentItemSummary.rows.length > 0
      .table-responsive
        table.table.table-striped.table-hover.mb-0
          thead
            tr
              th Item code
              th Cases
              th Entries
              th Latest complaint
          tbody
            each item in recentItemSummary.rows
              tr
                th(scope='row')
                  a.ct-defect-item-link(href=item.url)= item.itemCode
                td= item.caseCount
                td= item.occurrenceCount
                td
                  span.badge.badge-warning= item.latestComplaintDate
    else
      .card-body
        p.text-muted.mb-0 No item currently meets both the repeated-case and recent-complaint criteria.

  .card.mb-4
    .card-body
      .d-flex.flex-column.flex-md-row.justify-content-between.align-items-md-center.mb-3
        div
          h2.h4.mb-1 My Open Cases
          p.text-muted.mb-0= `${myCases.length} assigned to you · ${totalOpenCases} open overall · ${totalCases} total recorded`
      if myCases.length > 0
        +openCaseTable(myCases, false)
      else
        p.text-muted.mb-0 You have no open cases assigned to you.

  details.card.ct-case-disclosure
    summary.card-header.d-flex.justify-content-between.align-items-center
      span
        span.ct-disclosure-indicator.mr-2(aria-hidden='true') ▶
        strong Other Staff and Unassigned Cases
        small.text-muted.ml-2 Oldest updates first
      span.badge.badge-secondary= otherCases.length
    .card-body.p-0
      if otherCases.length > 0
        +openCaseTable(otherCases, true)
      else
        p.text-muted.m-3 No other open cases.
